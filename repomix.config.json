{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml"
  },
  "ignore": {
    "customPatterns": [
      "**/__pycache__/**",
      "**/venv/**",
      "**/.venv/**",
      "**/models/**",
      "**/templates/**",
      "**/*.pt",
      "**/*.onnx",
      "**/*.png",
      "**/*.jpg",
      "**/*.pyc",
      ".git/**",
      "README.md",
      "ARCHITECTURE.md",
      "CONTEXT.md"
    ],
    "useGitignore": true,
    "useDefaultPatterns": true
  }
}